	for arenaModel, seats in pairs(seatByArena) do
		if seats and (seats.W == player or seats.B == player) then
			local gs = gameStates[arenaModel]
			if gs and (not gs.status or gs.status == "playing") then
				local side = player:GetAttribute("Side")
				if side == "W" or side == "B" then
					-- call same logic path
					pcall(function()
						HandleMatchRequest(player, arenaModel, { type="RESIGN" }, "Disconnect")
					end)
				end
			end
			removeSeat(arenaModel, player)
		else
			removeSeat(arenaModel, player)
		end
	end
end)

