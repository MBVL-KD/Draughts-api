local getSettingsFunc = eventsFolder:WaitForChild("GetPlayerSettings")
local settingsChanged = eventsFolder:FindFirstChild("PlayerSettingsChanged")

local localSettings: {[string]: any} = {}

local function safeRequire(mod)
	local ok, m = pcall(function() return require(mod) end)
	return ok and m or nil
end

local Modules = ReplicatedStorage:FindFirstChild("Modules")
local PlayerSettings = Modules and safeRequire(Modules:FindFirstChild("PlayerSettings")) or nil

-- ✅ NEW: ThemeApplier (client-side apply => per-player visuals)
local ThemeApplier = Modules and safeRequire(Modules:FindFirstChild("ThemeApplier")) or nil

local function getSetting(key: string, defaultValue: any)
	local v = localSettings[key]
	if v ~= nil then return v end
	return defaultValue
end

-- ✅ nil-safe placeholders
local function noop() end
local clearAllHighlights = noop
local applyTurnIndicator = noop
local detectWhiteSide = noop
local refreshQueued = false

function queueTurnRefresh()
	if refreshQueued then return end
	refreshQueued = true
	task.defer(function()
		refreshQueued = false
		if detectWhiteSide then detectWhiteSide() end
		if applyTurnIndicator then applyTurnIndicator() end
	end)
end

