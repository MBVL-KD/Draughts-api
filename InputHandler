local WHITE_SIDE_IS_MAXZ = true

detectWhiteSide = function()
	local pf = getPiecesFolder()
	if not pf then return end

	local sumW, nW = 0, 0
	local sumB, nB = 0, 0

	for _, pm in ipairs(pf:GetChildren()) do
		if pm:IsA("Model") and pm.PrimaryPart then
			local c = pm.PrimaryPart:GetAttribute("Color") or pm:GetAttribute("Color")
			if c == "W" then
				sumW += pm.PrimaryPart.Position.Z
				nW += 1
			elseif c == "B" then
				sumB += pm.PrimaryPart.Position.Z
				nB += 1
			end
		end
	end

	if nW >= 10 and nB >= 10 then
		local avgW = sumW / nW
		local avgB = sumB / nB
		WHITE_SIDE_IS_MAXZ = (avgW > avgB)
	end
end

local function zForSide(sideWB: "W"|"B", b)
	local whiteZ = WHITE_SIDE_IS_MAXZ and (b.maxZ + 1.2) or (b.minZ - 1.2)
	local blackZ = WHITE_SIDE_IS_MAXZ and (b.minZ - 1.2) or (b.maxZ + 1.2)
	return (sideWB == "W") and whiteZ or blackZ
end

