local function onClick()
	if isAnimatingMove then return end

	local target = mouse.Target
	if not target then
		deselect()
		return
	end

	local piece = getPieceModelFromPart(target)
	if piece then
		jumpPieceVisual(piece)
		if not canInteractWithPiece(piece) then
			deselect()
			return
		end
		local fromSq = getCurrentSquareFromPiece(piece)
		if not fromSq then
			deselect()
			return
		end
		if selectedFrom == fromSq then
			deselect()
		else
			setSelection(fromSq)
		end
		return
	end

	local clickedSq = getSquareIdFromBoardClick(target)
	if not clickedSq then
		deselect()
		return
	end

	if selectedFrom then
		if isLegal(clickedSq) then
			local fromSaved = selectedFrom
			deselect()
			requestMove:FireServer(arena, fromSaved, clickedSq)
		end
		return
	end

	local pieceOn = getPieceOnSquare(clickedSq)
	if pieceOn then
		if not canInteractWithPiece(pieceOn) then
			deselect()
			return
		end
		setSelection(clickedSq)
	else
		deselect()
	end
end

