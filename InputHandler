local function tweenModelPivot(model: Model, goalCF: CFrame, duration: number)
	if not model or not model.Parent then return end

	local cfv = Instance.new("CFrameValue")
	cfv.Value = model:GetPivot()
	cfv.Parent = model

	local conn
	conn = cfv.Changed:Connect(function(v)
		if model.Parent then
			model:PivotTo(v)
		else
			if conn then conn:Disconnect() end
			cfv:Destroy()
		end
	end)

	local tw = TweenService:Create(
		cfv,
		TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
		{ Value = goalCF }
	)

	tw:Play()
	tw.Completed:Once(function()
		if conn then conn:Disconnect() end
		cfv:Destroy()
	end)
end

local function playSinkEffect(pieceModel: Model)
	if not pieceModel or not pieceModel.Parent then return end

	local parts = {}
	local anchoredPrev = {}
	for _, d in ipairs(pieceModel:GetDescendants()) do
		if d:IsA("BasePart") then
			table.insert(parts, d)
			anchoredPrev[d] = d.Anchored
			d.Anchored = true
		end
	end

	local duration = 0.55 / getAnimSpeed()
	local dropY = 2.0
	local startCF = pieceModel:GetPivot()
	local startPos = startCF.Position
	local rotOnly = startCF - startPos

	local goalPos = startPos + Vector3.new(0, -dropY, 0)
	local goalCF = CFrame.new(goalPos) * rotOnly

	tweenModelPivot(pieceModel, goalCF, duration)

	local tinfo = TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
	for _, p in ipairs(parts) do
		pcall(function()
			TweenService:Create(p, tinfo, {
				Transparency = math.min(1, p.Transparency + 0.75),
			}):Play()
		end)
	end

	task.delay(duration, function()
		for _, p in ipairs(parts) do
			if p and p.Parent then
				p.Anchored = anchoredPrev[p] == true
			end
		end
	end)
end

local function playCaptureEffectOnPiece(pieceModel: Model)
	if not pieceModel or not pieceModel.PrimaryPart then return end

	local effect = tostring(getCaptureEffect()) or "None"
	if effect == "None" then return end

	local visual = pieceModel:FindFirstChild("PieceVisual")
	local targetModel = (visual and visual:IsA("Model")) and visual or pieceModel

	local motor = pieceModel.PrimaryPart:FindFirstChild("PieceVisualMotor")
	if motor and motor:IsA("Motor6D") then
		local parts = {}
		for _, d in ipairs(targetModel:GetDescendants()) do
			if d:IsA("BasePart") then table.insert(parts, d) end
		end

		if effect == "Sink" then
			local t = 0.90 / getAnimSpeed()
			local dist = 9.0
			local tinfo = TweenInfo.new(t, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

			for _, p in ipairs(parts) do
				pcall(function()
					p.CanCollide = false
					p.CanTouch = false
					p.CanQuery = false
				end)
			end

			for _, p in ipairs(parts) do
				pcall(function()
					TweenService:Create(p, tinfo, {
						Transparency = math.min(1, p.Transparency + 0.85)
					}):Play()
				end)
			end

			local part0 = motor.Part0
			if part0 then
				local localDown = part0.CFrame:VectorToObjectSpace(Vector3.new(0, -dist, 0))
				pcall(function()
					TweenService:Create(motor, tinfo, {
						Transform = CFrame.new(localDown)
					}):Play()
				end)
			end

		elseif effect == "Explode" then
			local t = 0.35 / getAnimSpeed()
			local tinfo = TweenInfo.new(t, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

			local part0 = motor.Part0
			if part0 then
				local localUp = part0.CFrame:VectorToObjectSpace(Vector3.new(0, 0.8, 0))
				pcall(function()
					TweenService:Create(motor, tinfo, {
						Transform = CFrame.new(localUp)
					}):Play()
				end)
			end

			for _, p in ipairs(parts) do
				pcall(function()
					TweenService:Create(p, tinfo, {
						Transparency = math.min(1, p.Transparency + 0.9)
					}):Play()
				end)
			end
		end

		return
	end

	local parts = {}
	for _, d in ipairs(targetModel:GetDescendants()) do
		if d:IsA("BasePart") then table.insert(parts, d) end
	end

	if effect == "Sink" then
		playSinkEffect(pieceModel)
		return
	elseif effect == "Explode" then
		local t = 0.35 / getAnimSpeed()
		local tinfo = TweenInfo.new(t, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
		for _, p in ipairs(parts) do
			pcall(function()
				TweenService:Create(p, tinfo, {
					Transparency = math.min(1, p.Transparency + 0.9),
					Size = p.Size * 1.25,
				}):Play()
			end)
		end
	end
end

