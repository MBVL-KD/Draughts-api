local function getVisualMotor(pieceModel: Model): Motor6D?
	if not (pieceModel and pieceModel.PrimaryPart) then return nil end
	local m = pieceModel.PrimaryPart:FindFirstChild("PieceVisualMotor")
	if m and m:IsA("Motor6D") then return m end
	return nil
end

local function walkVisualToSquare(pieceModel: Model, toSq: number)
	local motor = getVisualMotor(pieceModel)
	if not motor then return end

	local sqPart = getSquarePartById(toSq)
	if not sqPart then return end

	local part0 = motor.Part0
	if not part0 then return end

	-- world positions (flat)
	local fromPos = pieceModel.PrimaryPart.Position
	local toPos = sqPart.Position
	local worldDelta = Vector3.new(toPos.X - fromPos.X, 0, toPos.Z - fromPos.Z)
	local dist = worldDelta.Magnitude
	if dist < 0.01 then return end

	-- speed control (studs/sec)
	local walkSpeed = tonumber(getSetting("WalkSpeed", 14)) or 14
	local duration = dist / math.max(1, walkSpeed)

	-- ✅ convert WORLD delta to PART0 LOCAL delta
	local localDelta = part0.CFrame:VectorToObjectSpace(worldDelta)

	-- tween motor transform
	local tw = TweenService:Create(
		motor,
		TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
		{ Transform = CFrame.new(localDelta) }
	)

	tw:Play()
	tw.Completed:Once(function()
		motor.Transform = CFrame.new()
	end)
end

local function setHitboxVisible(pieceModel: Model, visible: boolean)
	for _, d in ipairs(pieceModel:GetDescendants()) do
		if d:IsA("BasePart") then
			if d:FindFirstAncestor("PieceVisual") == nil then
				d.LocalTransparencyModifier = visible and 0 or 1
			end
		end
	end
end

local function setVisualVisible(pieceModel: Model, visible: boolean)
	local visual = pieceModel:FindFirstChild("PieceVisual")
	if not (visual and visual:IsA("Model")) then return end
	for _, d in ipairs(visual:GetDescendants()) do
		if d:IsA("BasePart") then
			d.LocalTransparencyModifier = visible and 0 or 1
		end
	end
end

local jumping = {} :: {[Model]: boolean}

local function jumpPieceVisual(pieceModel: Model)
	if jumping[pieceModel] then return end

	local motor = pieceModel.PrimaryPart and pieceModel.PrimaryPart:FindFirstChild("PieceVisualMotor")
	if not (motor and motor:IsA("Motor6D")) then
		return
	end

	jumping[pieceModel] = true

	local up = 0.9
	local tUp = 0.10
	local tDown = 0.12

	local twUp = TweenService:Create(
		motor,
		TweenInfo.new(tUp, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ Transform = CFrame.new(0, up, 0) }
	)
	local twDown = TweenService:Create(
		motor,
		TweenInfo.new(tDown, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
		{ Transform = CFrame.new() }
	)

	twUp:Play()
	twUp.Completed:Once(function() twDown:Play() end)
	twDown.Completed:Once(function()
		jumping[pieceModel] = nil
	end)
end

local selectedFrom: number? = nil
