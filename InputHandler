local function normalizeSquaresList(v): {number}
	local out = {}
	if type(v) ~= "table" then return out end
	for _, x in ipairs(v) do
		local n = tonumber(x)
		if n then table.insert(out, n) end
	end
	return out
end

local function getCapturedSquaresFromMoveData(moveData): {number}
	if type(moveData) ~= "table" then return {} end

	if type(moveData.capturedSquares) == "table" then
		return normalizeSquaresList(moveData.capturedSquares)
	end

	if type(moveData.captured) == "table" then
		return normalizeSquaresList(moveData.captured)
	end

	if type(moveData.captures) == "table" then
		local out = {}
		for _, c in ipairs(moveData.captures) do
			if type(c) == "number" then
				table.insert(out, c)
			elseif type(c) == "table" then
				local n = tonumber(c.square or c.sq or c.at)
				if n then table.insert(out, n) end
			end
		end
		return out
	end

	return {}
end

local function getPathSquaresFromMoveData(moveData): {number}
	if type(moveData) ~= "table" then return {} end
	if type(moveData.path) == "table" then
		return normalizeSquaresList(moveData.path)
	end
	local f = tonumber(moveData.from)
	local t = tonumber(moveData.to)
	local out = {}
	if f then table.insert(out, f) end
	if t then table.insert(out, t) end
	return out
end

moveExecuted.OnClientEvent:Connect(function(arenaModel, moveData)
	local skipWalk = lastMoveWasDrag
	lastMoveWasDrag = false
	clearAllHighlights()
	if arenaModel ~= arena then return end

	if dragging then
		if draggedRealPiece then
			setPieceVisible(draggedRealPiece, true)
		end
		destroyGhost()
		dragging = false
		draggedRealPiece = nil
		dragBaseY = nil
		snapTargetSq = nil
		isPointerDown = false
		downPiece = nil
		downFromSq = nil
	end

	isAnimatingMove = true

	local fromSq = (type(moveData) == "table") and tonumber(moveData.from) or nil
	local toSq   = (type(moveData) == "table") and tonumber(moveData.to) or nil

	if toSq then
		local moved = fromSq and getPieceOnSquare(fromSq) or nil
		if not moved and toSq then
			moved = getPieceOnSquare(toSq)
		end
		if moved and not skipWalk then
			walkVisualToSquare(moved, toSq)
		end
	end

	local capturedSquares = getCapturedSquaresFromMoveData(moveData)
	local pathSquares = getPathSquaresFromMoveData(moveData)

	local lastMoveMarks = {}
	if fromSq then table.insert(lastMoveMarks, fromSq) end
	if toSq then table.insert(lastMoveMarks, toSq) end
	for _, csq in ipairs(capturedSquares) do
		table.insert(lastMoveMarks, csq)
	end

	showLastMoveSquares(lastMoveMarks)
	applyTurnIndicator()

	if #capturedSquares > 0 then
		local capturer = currentTurn
		if not gameStateUpdated then
			capturer = (currentTurn == "W") and "B" or "W"
		end
		if capturer == "W" then
			capturedByW += #capturedSquares
		else
			capturedByB += #capturedSquares
		end
		updateCounterUI()
	end

	if #pathSquares >= 2 and #capturedSquares > 0 and getSetting("ShowLastMove", true) then
		for i = 2, #pathSquares do
			local stepTo = pathSquares[i]
			local stepFrom = pathSquares[i-1]

			local stepMarks = { stepFrom, stepTo }
			for _, csq in ipairs(capturedSquares) do table.insert(stepMarks, csq) end
			showLastMoveSquares(stepMarks)

			scaledWait(getCaptureStepWait())
		end
	end

	if #capturedSquares > 0 then
		if type(moveData) == "table" and type(moveData.capturedPieces) == "table" then
			for _, victim in ipairs(moveData.capturedPieces) do
				if typeof(victim) == "Instance" and victim:IsA("Model") then
					playCaptureEffectOnPiece(victim)
				end
			end
		else
			for _, csq in ipairs(capturedSquares) do
				local victim = getPieceOnSquare(csq)
				if victim then
					playCaptureEffectOnPiece(victim)
				end
			end
		end

		scaledWait(getCaptureStepWait())
	end

	-- ✅ BELANGRIJK:
	-- ❌ GEEN client-side snapPieceToSquareTop() meer.
	-- De SERVER (GameService.UpdatePhysicalPieces) bepaalt de exacte hoogte.

	selectedFrom = nil
	legalDests = {}
	isAnimatingMove = false
end)

