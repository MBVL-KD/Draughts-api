local turnFX = {
	folder = nil :: Folder?,
	mode = "None",

	barW = nil :: BasePart?,
	barB = nil :: BasePart?,

	runnerBackW = nil :: BasePart?,
	runnerW     = nil :: BasePart?,
	runnerBackB = nil :: BasePart?,
	runnerB     = nil :: BasePart?,
	runnerConn  = nil :: RBXScriptConnection?,

	cornersW = {} :: {BasePart},
	cornersB = {} :: {BasePart},
}

local function ensureTurnFolder()
	if turnFX.folder and turnFX.folder.Parent then return end
	local f = arena:FindFirstChild("TurnIndicators")
	if not f then
		f = Instance.new("Folder")
		f.Name = "TurnIndicators"
		f.Parent = arena
	end
	turnFX.folder = f
end

local function kill(x)
	if x and x.Parent then x:Destroy() end
end

local function clearTurnObjects()
	if turnFX.runnerConn then turnFX.runnerConn:Disconnect(); turnFX.runnerConn = nil end

	kill(turnFX.barW); turnFX.barW = nil
	kill(turnFX.barB); turnFX.barB = nil

	kill(turnFX.runnerBackW); turnFX.runnerBackW = nil
	kill(turnFX.runnerW);     turnFX.runnerW = nil
	kill(turnFX.runnerBackB); turnFX.runnerBackB = nil
	kill(turnFX.runnerB);     turnFX.runnerB = nil

	for _, p in ipairs(turnFX.cornersW) do kill(p) end
	for _, p in ipairs(turnFX.cornersB) do kill(p) end
	turnFX.cornersW = {}
	turnFX.cornersB = {}
end

local function makeNeonPart(name: string): Part
	ensureTurnFolder()
	local p = Instance.new("Part")
	p.Name = name
	p.Anchored = true
	p.CanCollide = false
	p.CanTouch = false
	p.CanQuery = false
	p.Material = Enum.Material.Neon
	p.Color = Color3.fromRGB(255,255,255)
	p.Transparency = 1
	p.Parent = turnFX.folder
	return p
end

local function layoutBars()
	local b = getBoardBounds()
	local y = b.y + 0.2
	local w = (b.maxX - b.minX)

	local barH = 0.35
	local barT = 0.55

	turnFX.barW.Size = Vector3.new(w, barH, barT)
	turnFX.barW.Position = Vector3.new(0, y, zForSide("W", b))

	turnFX.barB.Size = Vector3.new(w, barH, barT)
	turnFX.barB.Position = Vector3.new(0, y, zForSide("B", b))
end

local function layoutRunnerLane(side: "W"|"B")
	local b = getBoardBounds()
	local y = b.y + 0.2
	local w = (b.maxX - b.minX)
	local z = zForSide(side, b)

	local back = (side == "W") and turnFX.runnerBackW or turnFX.runnerBackB
	local run  = (side == "W") and turnFX.runnerW     or turnFX.runnerB
	if not back or not run then return end

	back.Size = Vector3.new(w, 0.18, 0.25)
	back.Position = Vector3.new(0, y, z)

	run.Size = Vector3.new(2.2, 0.35, 0.45)
	run.Position = Vector3.new(0, y + 0.05, z)
end

local function layoutCornersSide(side: "W"|"B")
	local b = getBoardBounds()
	local y = b.y + 0.9
	local z = zForSide(side, b)

	local leftX  = b.minX + 1.2
	local rightX = b.maxX - 1.2

	local function lamp(name, pos: Vector3, size: Vector3)
		local p = makeNeonPart(name)
		p.Size = size
		p.Position = pos
		return p
	end

	local bump = (side == "W") and 0.7 or -0.7
	local arr = {
		lamp(("Corner_%s_1"):format(side), Vector3.new(leftX,  y, z), Vector3.new(0.7,0.7,0.7)),
		lamp(("Corner_%s_2"):format(side), Vector3.new(rightX, y, z), Vector3.new(0.7,0.7,0.7)),
		lamp(("Corner_%s_3"):format(side), Vector3.new(leftX,  y+0.2, z + bump), Vector3.new(0.55,0.55,0.55)),
		lamp(("Corner_%s_4"):format(side), Vector3.new(rightX, y+0.2, z + bump), Vector3.new(0.55,0.55,0.55)),
	}

	if side == "W" then turnFX.cornersW = arr else turnFX.cornersB = arr end
end

local function buildTurnIndicator(mode: string)
	turnFX.mode = mode
	ensureTurnFolder()
	clearTurnObjects()

	if mode == "None" then return end

	if mode == "BarBehindBoard" then
		turnFX.barW = makeNeonPart("TurnBar_W")
		turnFX.barB = makeNeonPart("TurnBar_B")
		layoutBars()

	elseif mode == "MovingLine" then
		turnFX.runnerBackW = makeNeonPart("RunnerBack_W")
		turnFX.runnerW     = makeNeonPart("Runner_W")
		turnFX.runnerBackB = makeNeonPart("RunnerBack_B")
		turnFX.runnerB     = makeNeonPart("Runner_B")

		turnFX.runnerBackW.Transparency = 0.85
		turnFX.runnerBackB.Transparency = 0.85

		layoutRunnerLane("W")
		layoutRunnerLane("B")

	elseif mode == "CornerLight" then
		layoutCornersSide("W")
		layoutCornersSide("B")
	end
end

applyTurnIndicator = function()
	local mode = getTurnIndicatorMode()
	if mode ~= turnFX.mode then
		buildTurnIndicator(mode)
	end

	local ON  = 0.20
	local DIM = 0.85
	local OFF = 1.00

	local turn = currentTurn

	if turnFX.mode == "BarBehindBoard" then
		if turnFX.barW then turnFX.barW.Transparency = (turn=="W") and ON or DIM end
		if turnFX.barB then turnFX.barB.Transparency = (turn=="B") and ON or DIM end
		return
	end

	if turnFX.mode == "CornerLight" then
		for _, p in ipairs(turnFX.cornersW) do if p then p.Transparency = (turn=="W") and 0.10 or OFF end end
		for _, p in ipairs(turnFX.cornersB) do if p then p.Transparency = (turn=="B") and 0.10 or OFF end end
		return
	end

	if turnFX.mode == "MovingLine" then
		if turnFX.runnerConn then turnFX.runnerConn:Disconnect(); turnFX.runnerConn = nil end

		local showW = (turn=="W")
		local showB = (turn=="B")

		if turnFX.runnerBackW then turnFX.runnerBackW.Transparency = showW and 0.85 or OFF end
		if turnFX.runnerW     then turnFX.runnerW.Transparency     = showW and 0.15 or OFF end
		if turnFX.runnerBackB then turnFX.runnerBackB.Transparency = showB and 0.85 or OFF end
		if turnFX.runnerB     then turnFX.runnerB.Transparency     = showB and 0.15 or OFF end

		local activeRunner = showW and turnFX.runnerW or (showB and turnFX.runnerB or nil)
		local activeSide   = showW and "W" or (showB and "B" or nil)
		if not activeRunner or not activeSide then return end

		local t0 = os.clock()
		turnFX.runnerConn = RunService.RenderStepped:Connect(function()
			local b = getBoardBounds()
			local y = b.y + 0.25
			local w = (b.maxX - b.minX)
			local z = zForSide(activeSide, b)

			local span = math.max(2, w - 2)
			local x = (math.sin((os.clock()-t0) * 2.2) * 0.5 + 0.5) * span + (b.minX + 1)
			activeRunner.Position = Vector3.new(x, y, z)
		end)
	end
end

