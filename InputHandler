-- ============================================================================
-- PIECE & SQUARE HELPERS
-- ============================================================================
local PIECE_LIFT_EPS = 0.03

local function getSquarePartById(squareId: number): BasePart? end

local function getTileTopY(squareId: number): number?
	local tile = getSquarePartById(squareId)
	if not tile then return nil end
	return tile.Position.Y + (tile.Size.Y * 0.5)
end

local function snapPieceToSquareTop(pieceModel: Model, squareId: number)
	if not pieceModel or not pieceModel.PrimaryPart then return end

	local tile = getSquarePartById(squareId)
	if not tile then return end

	-- EXACT tile top
	local tileTopY = tile.Position.Y + (tile.Size.Y * 0.5)

	local pp = pieceModel.PrimaryPart
	local ppHalf = pp.Size.Y * 0.5

	-- Doel: PrimaryPart bodem exact op tile top
	local desiredY = tileTopY + ppHalf + PIECE_LIFT_EPS

	local curCF = pieceModel:GetPivot()
	local curPos = curCF.Position

	-- Alleen Y corrigeren, X/Z laten zoals server die zet
	if math.abs(curPos.Y - desiredY) < 0.001 then return end

	pieceModel:PivotTo(
		CFrame.new(curPos.X, desiredY, curPos.Z) * (curCF - curPos)
	)
end

local function getPieceColor(pieceModel: Model): string?
	local attr = pieceModel:GetAttribute("Color") or pieceModel:GetAttribute("PieceColor")
	if attr == "W" or attr == "B" then return attr end

	if pieceModel.PrimaryPart then
		local a2 = pieceModel.PrimaryPart:GetAttribute("Color")
		if a2 == "W" or a2 == "B" then return a2 end
		local sv = pieceModel.PrimaryPart:FindFirstChild("PieceColor")
		if sv and sv:IsA("StringValue") and (sv.Value == "W" or sv.Value == "B") then
			return sv.Value
		end
	end

	local name = pieceModel.Name
	if string.find(name, "Piece_W") or string.find(name, "_W_") then return "W" end
	if string.find(name, "Piece_B") or string.find(name, "_B_") then return "B" end
	return nil
end

local function canInteractWithPiece(pieceModel: Model): boolean
	local c = getPieceColor(pieceModel)
	if not c then return true end
	return c == currentTurn
end

local function getSquareRootFromPart(part: Instance): Instance?
	if not part then return nil end
	if not part:IsDescendantOf(board) then return nil end
	local cur: Instance? = part
	while cur and cur.Parent ~= board do
		cur = cur.Parent
	end
	return cur
end

local function getSquareIdFromSquareRoot(squareRoot: Instance): number?
	local sid = squareRoot:FindFirstChild("SquareId")
	if sid and sid:IsA("ValueBase") then
		return tonumber((sid :: any).Value)
	end
	return nil
end

local function getSquareIdFromBoardClick(part: Instance): number?
	local squareRoot = getSquareRootFromPart(part)
	if not squareRoot then return nil end
	return getSquareIdFromSquareRoot(squareRoot)
end

function getSquarePartById(squareId: number): BasePart?
	for _, sq in ipairs(board:GetChildren()) do
		if sq:IsA("BasePart") then
			local sid = sq:FindFirstChild("SquareId")
			if sid and sid:IsA("ValueBase") and tonumber((sid :: any).Value) == squareId then
				return sq
			end
		end
	end
	return nil
end

local function getPieceModelFromPart(part: Instance): Model?
	if not part then return nil end

	local pf = getPiecesFolder()

	if pf and part:IsDescendantOf(pf) then
		local m = part:FindFirstAncestorOfClass("Model")
		while m and m.Parent ~= pf do
			m = m.Parent and m.Parent:FindFirstAncestorOfClass("Model") or nil
		end
		if m and m.Parent == pf then
			return m
		end
	end

	local visual = part:FindFirstAncestor("PieceVisual")
	if visual and visual:IsA("Model") then
		local maybePiece = visual.Parent
		if maybePiece and maybePiece:IsA("Model") and pf and maybePiece.Parent == pf then
			return maybePiece
		end
	end

	do
		local cur: Instance? = part
		while cur do
			if cur:IsA("Model") and pf and cur.Parent == pf then
				return cur
			end
			cur = cur.Parent
		end
	end

	return nil
end

local function getCurrentSquareFromPiece(piece: Model): number?
	if not piece.PrimaryPart then return nil end
	local cs = piece.PrimaryPart:FindFirstChild("CurrentSquare")
	if cs and cs:IsA("ValueBase") then
		return tonumber((cs :: any).Value)
	end
	local a = piece.PrimaryPart:GetAttribute("Square")
	if a then return tonumber(a) end
	return nil
end

local function getPieceOnSquare(squareNumber: number): Model?
	local pf = getPiecesFolder()
	if not pf then return nil end

	for _, piece in ipairs(pf:GetChildren()) do
		if piece:IsA("Model") and piece.PrimaryPart then
			local cs = piece.PrimaryPart:FindFirstChild("CurrentSquare")
			if cs and cs:IsA("ValueBase") and tonumber((cs :: any).Value) == squareNumber then
				return piece
			end
			local a = piece.PrimaryPart:GetAttribute("Square")
			if a and tonumber(a) == squareNumber then
				return piece
			end
		end
	end
	return nil
end

-- ============================================================================
-- BOARD BOUNDS
-- ============================================================================
local cachedBounds = nil

local function computeBoardBounds()
	local minX, maxX = math.huge, -math.huge
	local minZ, maxZ = math.huge, -math.huge
	local ySum, yCount = 0, 0

	for _, sq in ipairs(board:GetChildren()) do
		if sq:IsA("BasePart") then
			local p = sq.Position
			local sx, sz = sq.Size.X * 0.5, sq.Size.Z * 0.5
			minX = math.min(minX, p.X - sx)
			maxX = math.max(maxX, p.X + sx)
			minZ = math.min(minZ, p.Z - sz)
			maxZ = math.max(maxZ, p.Z + sz)
			ySum += p.Y
			yCount += 1
		end
	end

	if yCount == 0 then
		return {minX=-20, maxX=20, minZ=-20, maxZ=20, y=0}
	end

	return {
		minX = minX, maxX = maxX,
		minZ = minZ, maxZ = maxZ,
		y = ySum / yCount
	}
end

local function getBoardBounds()
	if not cachedBounds then
		cachedBounds = computeBoardBounds()
	end
	return cachedBounds
end

local function clampToBoard(pos: Vector3)
	local b = getBoardBounds()
	return Vector3.new(
		math.clamp(pos.X, b.minX, b.maxX),
		pos.Y,
		math.clamp(pos.Z, b.minZ, b.maxZ)
	)
end

-- ============================================================================
-- HIGHLIGHTS (BULLETPROOF)
-- ============================================================================
local HL_ATTR = "_HL"

local function cacheOriginalIfNeeded(sq: BasePart)
	if originalProps[sq] then return end
	originalProps[sq] = {
		Color = sq.Color,
		Material = sq.Material,
		Transparency = sq.Transparency,
	}
end

local function restoreSquareProps(sq: BasePart)
	local p = originalProps[sq]
	if not p then
		cacheOriginalIfNeeded(sq)
		p = originalProps[sq]
	end
	sq.Color = p.Color
	sq.Material = p.Material
	sq.Transparency = p.Transparency
	sq:SetAttribute(HL_ATTR, nil)
end

clearAllHighlights = function()
	for _, sq in ipairs(board:GetChildren()) do
		if sq:IsA("BasePart") then
			local tag = sq:GetAttribute(HL_ATTR)
			if tag ~= nil then
				restoreSquareProps(sq)
			end
		end
	end
end

local function markDestination(squareId: number)
	local sq = getSquarePartById(squareId)
	if not sq then return end
	cacheOriginalIfNeeded(sq)

	sq.Material = Enum.Material.SmoothPlastic
	sq.Transparency = 0.25
	sq.Color = Color3.fromRGB(75, 151, 75)
	sq:SetAttribute(HL_ATTR, "dest")
end

local function markLastMove(squareId: number)
	local sq = getSquarePartById(squareId)
	if not sq then return end
	cacheOriginalIfNeeded(sq)

	sq.Material = Enum.Material.SmoothPlastic
	sq.Transparency = 0.30
	sq.Color = Color3.fromRGB(44, 101, 29)
	sq:SetAttribute(HL_ATTR, "last")
end

local function showDestinations(dests: {number})
	clearAllHighlights()
	if not getSetting("ShowHighlights", true) then return end
	for _, d in ipairs(dests) do
		markDestination(d)
	end
end

local function showLastMoveSquares(squares: {number})
	clearAllHighlights()
	if not getSetting("ShowLastMove", true) then return end
	for _, sqId in ipairs(squares) do
		markLastMove(sqId)
	end
end

