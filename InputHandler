-- ============================================================================
-- ✅ THEME APPLY (client-side, per player)
-- - Applies to arena.Board + arena.Border
-- - Must reset highlight cache after apply so restore works
-- ============================================================================
local originalProps: {[BasePart]: {Color: Color3, Material: Enum.Material, Transparency: number}} = {} -- forward-declared for reset
local function resetHighlightCache()
	originalProps = {}
end

local function applyBoardThemeNow()
	if not ThemeApplier then return end
	local themeId = getBoardTheme()
	pcall(function()
		ThemeApplier.ApplyBoardTheme(arena, themeId)
	end)
	-- After theme changes, any cached "original" tile styles are stale
	resetHighlightCache()
	-- Clear any active highlight markings and restore from new theme baseline
	clearAllHighlights()
end

-- Load settings snapshot
task.spawn(function()
	task.wait(0.2)
	local ok, snapshot = pcall(function()
		return getSettingsFunc:InvokeServer()
	end)
	if ok and type(snapshot) == "table" then
		for k, v in pairs(snapshot) do
			localSettings[k] = v
		end
	end

	-- ✅ Apply board theme after we have settings
	applyBoardThemeNow()

	-- react on settings
	if localSettings.ShowHighlights == false or localSettings.ShowLastMove == false then
		clearAllHighlights()
	end
	applyTurnIndicator()
end)

-- Settings change stream
if settingsChanged then
	settingsChanged.OnClientEvent:Connect(function(key, value)
		if key == "_SNAPSHOT_" and type(value) == "table" then
			for k, v in pairs(value) do
				localSettings[k] = v
			end

			-- ✅ apply theme (snapshot may include BoardTheme)
			applyBoardThemeNow()

			if localSettings.ShowHighlights == false or localSettings.ShowLastMove == false then
				clearAllHighlights()
			end
			applyTurnIndicator()
			return
		end

		if type(key) == "string" then
			localSettings[key] = value
		end

		if key == "ShowHighlights" and value == false then
			clearAllHighlights()
		elseif key == "ShowLastMove" and value == false then
			clearAllHighlights()
		elseif key == "TurnIndicatorMode" then
			applyTurnIndicator()
		elseif key == "BoardTheme" then
			-- ✅ NEW: live board theme change (per player)
			applyBoardThemeNow()
		end
	end)
end

