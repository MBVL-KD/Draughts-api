-- ============================================================================
-- DRAG
-- ============================================================================
local DRAG_START_PIXELS = 10
local DRAG_Y_OFFSET = 0.15
local MAGNET_DIST = 3
local MAGNET_TWEEN_TIME = 0

local isPointerDown = false
local downScreenPos: Vector2? = nil
local downPiece: Model? = nil
local downFromSq: number? = nil
local dragging = false
local ghost: Model? = nil
local dragConn: RBXScriptConnection? = nil
local snapTargetSq: number? = nil
local snapTween: Tween? = nil
local dragBaseY: number? = nil
local draggedRealPiece: Model? = nil

local function setPieceVisible(pieceModel: Model, visible: boolean)
	for _, d in ipairs(pieceModel:GetDescendants()) do
		if d:IsA("BasePart") then
			d.LocalTransparencyModifier = visible and 0 or 1
		end
	end
end

local function destroyGhost()
	if snapTween then snapTween:Cancel() snapTween = nil end
	snapTargetSq = nil
	if dragConn then dragConn:Disconnect() dragConn = nil end
	if ghost then ghost:Destroy() ghost = nil end
end

local function makeGhostFromPiece(piece: Model): Model?
	local visual = piece:FindFirstChild("PieceVisual")
	local source: Instance = (visual and visual:IsA("Model")) and visual or piece

	local g = source:Clone()
	g.Name = "GhostPiece"
	g.Parent = workspace

	for _, d in ipairs(g:GetDescendants()) do
		if d:IsA("BasePart") then
			d.Anchored = true
			d.CanCollide = false
			d.CanTouch = false
			d.CanQuery = false
			d.Transparency = math.clamp(d.Transparency + 0.25, 0, 0.7)
		end
	end

	if not g.PrimaryPart then
		g.PrimaryPart = g:FindFirstChildWhichIsA("BasePart", true)
	end

	if source:IsA("Model") then
		g:PivotTo(source:GetPivot())
	end

	return g
end

local function nearestLegalSquare(worldPos: Vector3): (number?, number?)
	if #legalDests == 0 then return nil, nil end
	local bestSq = nil
	local bestDist = math.huge
	for _, sqId in ipairs(legalDests) do
		local sqPart = getSquarePartById(sqId)
		if sqPart then
			local p = sqPart.Position
			local d = (Vector3.new(worldPos.X, 0, worldPos.Z) - Vector3.new(p.X, 0, p.Z)).Magnitude
			if d < bestDist then
				bestDist = d
				bestSq = sqId
			end
		end
	end
	return bestSq, bestDist
end

local function tweenGhostToSquare(squareId: number)
	if not ghost or not ghost.PrimaryPart then return end
	local sqPart = getSquarePartById(squareId)
	if not sqPart then return end

	local targetPos = sqPart.Position
	local current = ghost.PrimaryPart.CFrame
	local rotOnly = current - current.Position
	local y = (dragBaseY or targetPos.Y) + DRAG_Y_OFFSET
	local goal = CFrame.new(targetPos.X, y, targetPos.Z) * rotOnly

	if MAGNET_TWEEN_TIME <= 0 then
		if snapTween then snapTween:Cancel(); snapTween = nil end
		ghost.PrimaryPart.CFrame = goal
		return
	end

	if snapTween then snapTween:Cancel() snapTween = nil end
	snapTween = TweenService:Create(
		ghost.PrimaryPart,
		TweenInfo.new(MAGNET_TWEEN_TIME / getAnimSpeed(), Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ CFrame = goal }
	)
	snapTween:Play()
end

local function setSelection(fromSq: number)
	selectedFrom = fromSq
	clearAllHighlights()

	local ok, dests = pcall(function()
		return requestDestinations:InvokeServer(arena, fromSq)
	end)
	if not ok or type(dests) ~= "table" then
		legalDests = {}
		clearAllHighlights()
		return
	end

	local normalized = {}
	for _, v in ipairs(dests) do
		local n = tonumber(v)
		if n then table.insert(normalized, n) end
	end
	legalDests = normalized
	showDestinations(legalDests)

	if getSetting("AutoMoveSingle", false) and #legalDests == 1 then
		local only = legalDests[1]
		local fromNow = fromSq
		task.delay(0.25 / getAnimSpeed(), function()
			if dragging then return end
			if selectedFrom ~= fromNow then return end
			deselect()
			requestMove:FireServer(arena, fromNow, only)
		end)
	end
end

local function beginDrag(piece: Model, fromSq: number)
	if isAnimatingMove then return end
	if not canInteractWithPiece(piece) then
		deselect()
		return
	end

	dragging = true
	isPointerDown = true

	setSelection(fromSq)

	draggedRealPiece = piece
	setHitboxVisible(piece, false)
	setVisualVisible(piece, false)

	dragBaseY = (piece.PrimaryPart and piece.PrimaryPart.Position.Y) or nil
	ghost = makeGhostFromPiece(piece)

	dragConn = RunService.RenderStepped:Connect(function()
		if not ghost or not ghost.PrimaryPart then return end
		local wp = getMouseWorldPos()
		if not wp then return end

		local clamped = clampToBoard(wp)
		local current = ghost.PrimaryPart.CFrame
		local rotOnly = current - current.Position
		local y = (dragBaseY or ghost.PrimaryPart.Position.Y) + DRAG_Y_OFFSET
		local freeCF = CFrame.new(clamped.X, y, clamped.Z) * rotOnly

		local nearestSq, dist = nearestLegalSquare(clamped)
		if nearestSq and dist and dist <= MAGNET_DIST then
			if snapTargetSq ~= nearestSq then
				snapTargetSq = nearestSq
				tweenGhostToSquare(nearestSq)
			end
		else
			snapTargetSq = nil
			if snapTween then snapTween:Cancel() snapTween = nil end
			ghost.PrimaryPart.CFrame = freeCF
		end
	end)
end

local function endDrag()
	if not dragging then return end
	dragging = false

	local targetSq = snapTargetSq
	if not targetSq then
		local wp = getMouseWorldPos()
		if wp then
			local clamped = clampToBoard(wp)
			local nearestSq, dist = nearestLegalSquare(clamped)
			if nearestSq and dist and dist <= MAGNET_DIST then
				targetSq = nearestSq
			end
		end
	end

	local fromSaved = selectedFrom
	local legalSaved = legalDests
	local realPiece = draggedRealPiece

	local isValid = (fromSaved ~= nil) and (targetSq ~= nil) and table.find(legalSaved, targetSq) ~= nil

	if isValid and targetSq then
		destroyGhost()

		if realPiece then
			setVisualVisible(realPiece, true)
			local hasVisual = realPiece:FindFirstChild("PieceVisual") ~= nil
			setHitboxVisible(realPiece, not hasVisual)
		end

		draggedRealPiece = nil
		dragBaseY = nil
		snapTargetSq = nil

		deselect()
		lastMoveWasDrag = true
		requestMove:FireServer(arena, fromSaved, targetSq)
		return
	end

	destroyGhost()
	if realPiece then
		setVisualVisible(realPiece, true)
		local hasVisual = realPiece:FindFirstChild("PieceVisual") ~= nil
		setHitboxVisible(realPiece, not hasVisual)
	end
	draggedRealPiece = nil
	dragBaseY = nil
	snapTargetSq = nil
	deselect()
end

