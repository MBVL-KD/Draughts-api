-- ✅ IMPORTANT: Pieces folder is recreated on rematch; do NOT keep a fixed reference.
local piecesFolder: Folder? = nil

local function bindPiecesFolder(newFolder: Folder?)
	if newFolder and newFolder:IsA("Folder") then
		piecesFolder = newFolder
		-- When Pieces is replaced, cached bounds/highlights are fine,
		-- but turn-side detection needs a refresh.
		task.defer(function()
			queueTurnRefresh()
		end)
	end
end

local function getPiecesFolder(): Folder?
	if piecesFolder and piecesFolder.Parent then
		return piecesFolder
	end
	local f = arena:FindFirstChild("Pieces")
	if f and f:IsA("Folder") then
		bindPiecesFolder(f)
		return f
	end
	return nil
end

-- initial bind (if pieces exist already)
bindPiecesFolder(arena:FindFirstChild("Pieces") :: any)

-- listen for rematch rebuilds
arena.ChildAdded:Connect(function(child)
	if child.Name == "Pieces" and child:IsA("Folder") then
		task.defer(function()
			-- give spawner a moment to populate
			task.wait(0.05)
			bindPiecesFolder(child)
		end)
	end
end)

arena.ChildRemoved:Connect(function(child)
	if piecesFolder and child == piecesFolder then
		piecesFolder = nil
	end
end)

-- Remotes
local eventsFolder = ReplicatedStorage:WaitForChild("GameEvents")
local requestDestinations = eventsFolder:WaitForChild("RequestDestinations")
